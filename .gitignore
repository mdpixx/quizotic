# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Local design mockups — HTML explorations, not product code
/.mockups

# Local-only non-product directories — never commit. These are working
# artifacts on the developer's machine (Remotion promo project, planning
# notes, tool caches, HTML email/stage previews). They are NOT part of the
# app and must never enter git or the Docker build context.
# `promo-video/` in particular ships its own package.json + node_modules and
# a Remotion tsconfig that the root `next build` TS checker would walk into
# (see incident 2026-07-19 — `@remotion/cli/config` type error on Railway).
promo-video/
.zcode/
plans/
public/email-previews/
public/stage-previews/
rating-redesign-preview.html

# User-data exports — NEVER commit (PII). Generated by scripts/export-users-xlsx.mjs.
# These previously leaked into the public mdpixx/quizotic repo; keep them local only.
*.xlsx
quizotic_user*.html
exports/*users*

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# worktrees
.worktrees/
.superpowers/
.worktrees/

# Remotion
remotion/node_modules
remotion/out
remotion/.cache

# Tesseract.js language packs — downloaded at runtime by the worker on
# first use. ~5MB binaries; never commit. Railway re-downloads once per
# container restart and caches in memory thereafter.
*.traineddata
tessdata/

