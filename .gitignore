# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Local design mockups — HTML explorations, not product code
/.mockups

# User-data exports — NEVER commit (PII). Generated by scripts/export-users-xlsx.mjs.
# These previously leaked into the public mdpixx/quizotic repo; keep them local only.
*.xlsx
quizotic_user*.html
exports/*users*

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# worktrees
.worktrees/
.superpowers/
.worktrees/

# Remotion
remotion/node_modules
remotion/out
remotion/.cache

# Tesseract.js language packs — downloaded at runtime by the worker on
# first use. ~5MB binaries; never commit. Railway re-downloads once per
# container restart and caches in memory thereafter.
*.traineddata
tessdata/

