# Server
PORT=3000
NODE_ENV=development

# Domains (production only)
HOST_DOMAIN=https://quizotic.in
JOIN_DOMAIN=https://quizotic.net

# Database (Phase 3 — add when Prisma is set up)
# DATABASE_URL=postgresql://user:password@host:5432/quizotic

# Auth (Phase 3 — NextAuth)
# NEXTAUTH_SECRET=your-secret-here
# NEXTAUTH_URL=https://quizotic.in
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Payments (Phase 4 — Razorpay)
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=

# Email (Phase 4 — Resend)
# RESEND_API_KEY=

# AI Generation (OpenRouter — reuse from secrets vault)
OPENROUTER_API_KEY=
QUIZ_AI_MODEL=google/gemini-2.0-flash-001
