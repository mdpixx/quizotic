# Server
PORT=4000
NODE_ENV=development

# Database (Neon PostgreSQL or Railway PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/quizotic

# Auth (NextAuth v5)
AUTH_SECRET=               # Generate: openssl rand -base64 32
NEXTAUTH_SECRET=           # Same as AUTH_SECRET (used by socket auth)
NEXTAUTH_URL=http://localhost:4000
GOOGLE_CLIENT_ID=          # Google Cloud Console > OAuth 2.0 credentials
GOOGLE_CLIENT_SECRET=

# Payments — Razorpay (primary)
RAZORPAY_KEY_ID=           # Razorpay Dashboard > Settings > API Keys
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=   # Razorpay Dashboard > Settings > Webhooks
RAZORPAY_PLAN_MONTHLY=plan_xxx   # Subscription plan ID for monthly
RAZORPAY_PLAN_YEARLY=plan_xxx    # Subscription plan ID for yearly

# Email (Resend — deferred until Cloudflare DNS migration)
# RESEND_API_KEY=
# EMAIL_FROM=Quizotic <noreply@quizotic.live>

# Admin (comma-separated emails that can grant/revoke Pro)
ADMIN_EMAILS=

# PostHog Analytics (EU region)
NEXT_PUBLIC_POSTHOG_KEY=    # PostHog > Settings > Project API Key
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# AI Generation (OpenRouter)
OPENROUTER_API_KEY=
QUIZ_AI_MODEL=google/gemini-2.5-flash-preview-05-20
