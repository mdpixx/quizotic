# Server
PORT=4000
NODE_ENV=development

# Database (Neon PostgreSQL or Railway PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/quizotic

# Auth (NextAuth v5)
AUTH_SECRET=               # Generate: openssl rand -base64 32
NEXTAUTH_SECRET=           # Same as AUTH_SECRET (used by socket auth)
NEXTAUTH_URL=http://localhost:4000
GOOGLE_CLIENT_ID=          # Google Cloud Console > OAuth 2.0 credentials
GOOGLE_CLIENT_SECRET=

# Microsoft Entra ID (corporate O365 users — bypasses email-gateway magic-link blocks)
# Register at https://entra.microsoft.com > App registrations, any MS account type.
# Redirect URI: {NEXTAUTH_URL}/api/auth/callback/microsoft-entra-id
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
AUTH_MICROSOFT_ENTRA_ID_ISSUER=https://login.microsoftonline.com/common/v2.0

# Payments — Razorpay (primary)
RAZORPAY_KEY_ID=           # Razorpay Dashboard > Settings > API Keys
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=   # Razorpay Dashboard > Settings > Webhooks
RAZORPAY_PLAN_MONTHLY=plan_xxx   # Subscription plan ID for monthly
RAZORPAY_PLAN_YEARLY=plan_xxx    # Subscription plan ID for yearly

# Email (Resend — deferred until Cloudflare DNS migration)
# RESEND_API_KEY=
# EMAIL_FROM=Quizotic <noreply@quizotic.live>

# Admin (comma-separated emails that can grant/revoke Pro)
ADMIN_EMAILS=

# PostHog Analytics (EU region)
NEXT_PUBLIC_POSTHOG_KEY=    # PostHog > Settings > Project API Key
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Google Analytics 4 (Measurement ID from analytics.google.com > Admin > Data Streams)
NEXT_PUBLIC_GA4_ID=          # G-XXXXXXXXXX

# Search-engine site verification (set after creating the GSC / Bing properties)
NEXT_PUBLIC_GSC_VERIFICATION=    # Search Console > Settings > Ownership > HTML tag (content value)
NEXT_PUBLIC_BING_VERIFICATION=   # Bing Webmaster Tools meta-tag content value

# Cloudflare R2 (Image Storage for quiz questions)
R2_ACCOUNT_ID=              # Cloudflare Dashboard > R2 > bucket settings > S3 API
R2_ACCESS_KEY_ID=           # R2 API Tokens > Create API Token
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=quizotic-uploads
R2_PUBLIC_URL=              # R2 bucket > Public Development URL (https://pub-xxx.r2.dev)

# AI Generation (OpenRouter)
OPENROUTER_API_KEY=
QUIZ_AI_MODEL=google/gemini-2.5-flash-preview-05-20
