// This is your Prisma schema file
// Learn more about it at https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── User (NextAuth-compatible) ─────────────────────────────────
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  subscription  Subscription?
  payments      Payment[]
  usageLogs     UsageLog[]
  quizzes       Quiz[]
  presentations Presentation[]
  gameSessions  GameSession[]
}

// ─── NextAuth Account (OAuth providers) ─────────────────────────
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

// ─── NextAuth Session ───────────────────────────────────────────
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── NextAuth Verification Token (magic link) ───────────────────
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Subscription ───────────────────────────────────────────────
model Subscription {
  id                     String    @id @default(cuid())
  userId                 String    @unique
  plan                   String    @default("free") // "free" | "pro_monthly" | "pro_yearly"
  status                 String    @default("active") // "active" | "cancelled" | "past_due" | "expired"
  provider               String?   // "stripe" | "razorpay"
  providerSubscriptionId String?
  providerCustomerId     String?
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  cancelledAt            DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments Payment[]
}

// ─── Payment (audit trail) ──────────────────────────────────────
model Payment {
  id                String   @id @default(cuid())
  userId            String
  subscriptionId    String?
  provider          String   // "stripe" | "razorpay"
  providerPaymentId String   @unique
  providerEventId   String?  // webhook event ID for idempotency
  amount            Int      // in smallest unit: cents (USD) or paise (INR)
  currency          String   // "usd" | "inr"
  status            String   // "succeeded" | "failed" | "refunded"
  invoiceUrl        String?
  metadata          Json?    // raw webhook payload for audit
  createdAt         DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])

  @@index([userId])
  @@index([providerPaymentId])
}

// ─── UsageLog (AI rate limiting) ────────────────────────────────
model UsageLog {
  id        String   @id @default(cuid())
  userId    String
  action    String   // "ai_generate" | "ai_translate"
  metadata  Json?    // { model, questionCount, etc. }
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, action, createdAt])
}

// ─── Existing Models (modified) ─────────────────────────────────

model Quiz {
  id        String   @id @default(cuid())
  title     String
  subject   String?
  language  String?
  questions Json     // array of Question objects
  userId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User?         @relation(fields: [userId], references: [id])
  sessions GameSession[]

  @@index([userId])
}

model Presentation {
  id        String   @id @default(cuid())
  title     String
  slides    Json     // array of Slide objects
  userId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User?         @relation(fields: [userId], references: [id])
  sessions GameSession[]

  @@index([userId])
}

model GameSession {
  id               String        @id @default(cuid())
  code             String        @unique // 6-digit room code
  type             String        // 'quiz' | 'presentation'
  quizId           String?
  presentationId   String?
  userId           String?
  hostName         String?
  status           String        @default("waiting") // 'waiting' | 'active' | 'ended'
  results          Json?         // aggregate per-slide/question results
  participantCount Int           @default(0)
  createdAt        DateTime      @default(now())
  endedAt          DateTime?

  quiz         Quiz?         @relation(fields: [quizId], references: [id])
  presentation Presentation? @relation(fields: [presentationId], references: [id])
  user         User?         @relation(fields: [userId], references: [id])

  @@index([userId])
}
