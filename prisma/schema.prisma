// This is your Prisma schema file
// Learn more about it at https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── User (NextAuth-compatible) ─────────────────────────────────
model User {
  id               String    @id @default(cuid())
  name             String?
  email            String    @unique
  emailVerified    DateTime?
  image            String?
  role             String? // teacher, trainer, student, hr, manager, other
  orgType          String? // school, college, coaching, corporate, government, other
  organization     String? // school/company name
  onboarded        Boolean   @default(false)
  referralCode     String?   @unique // "mahesh-k7x2"
  referredByCode   String? // code used at signup
  discoveryChannel String? // "google" | "social" | "friend" | "event" | "other"
  apiKey           String?   @unique // Bearer token for Public REST API v1
  // Geo + activity (Session 2). country and locale are captured at first
  // sign-in from request headers and not overwritten on later logins.
  // lastActiveAt is debounce-updated by the auth helpers.
  lastActiveAt     DateTime?
  country          String? // ISO 3166-1 alpha-2 e.g. "IN", "US"
  locale           String? // BCP 47 e.g. "en-IN", "en-US"
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  accounts          Account[]
  sessions          Session[]
  subscription      Subscription?
  payments          Payment[]
  usageLogs         UsageLog[]
  quizzes           Quiz[]
  presentations     Presentation[]
  gameSessions      GameSession[]
  referralsGiven    Referral[]     @relation("referrals_given")
  referralsReceived Referral[]     @relation("referrals_received")
  creditGrants      CreditGrant[]
  emails            EmailLog[]
  couponRedemptions CouponRedemption[]
  deletionRequests  DataDeletionRequest[]
  moderationReports ModerationFlag[]   @relation("moderation_reports")
  flagAssignments   FeatureFlagAssignment[]

  @@index([lastActiveAt])
  @@index([country])
}

// ─── NextAuth Account (OAuth providers) ─────────────────────────
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

// ─── NextAuth Session ───────────────────────────────────────────
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── NextAuth Verification Token (magic link) ───────────────────
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Subscription ───────────────────────────────────────────────
model Subscription {
  id                     String    @id @default(cuid())
  userId                 String    @unique
  plan                   String    @default("free") // "free" | "pro_monthly" | "pro_yearly"
  status                 String    @default("active") // "active" | "cancelled" | "past_due" | "expired"
  provider               String? // "stripe" | "razorpay"
  providerSubscriptionId String?
  providerCustomerId     String?
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  cancelledAt            DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments Payment[]
}

// ─── Payment (audit trail) ──────────────────────────────────────
model Payment {
  id                String   @id @default(cuid())
  userId            String
  subscriptionId    String?
  provider          String // "stripe" | "razorpay"
  providerPaymentId String   @unique
  providerEventId   String?  @unique // webhook event ID for idempotency (race-safe dedupe)
  amount            Int // in smallest unit: cents (USD) or paise (INR)
  currency          String // "usd" | "inr"
  status            String // "succeeded" | "failed" | "refunded"
  invoiceUrl        String?
  metadata          Json? // raw webhook payload for audit
  createdAt         DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])

  @@index([userId])
  @@index([providerPaymentId])
}

// ─── UsageLog (AI rate limiting) ────────────────────────────────
// Quota math used to read `metadata.questionCount` out of the JSON blob,
// which made the entire monthly limit one schema-drift away from a billing
// incident. Session 2 promoted questionCount + model to typed columns.
// Historical rows were backfilled by the same migration.
model UsageLog {
  id            String   @id @default(cuid())
  userId        String
  action        String // "ai_generate" | "ai_translate" | "ai_enhance"
  questionCount Int      @default(0) // count for this single call (0 for non-question actions)
  model         String? // e.g. "google/gemini-2.0-flash-001"
  metadata      Json? // ad-hoc context: difficulty, mode, extractionSource, etc.
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, action, createdAt])
}

// ─── Existing Models (modified) ─────────────────────────────────

model Quiz {
  id        String   @id @default(cuid())
  title     String
  subject   String?
  language  String?
  theme     String? // theme id from QUIZ_THEMES catalog; null = default
  questions Json // array of Question objects
  userId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User?         @relation(fields: [userId], references: [id])
  sessions GameSession[]
  versions QuizVersion[]

  @@index([userId])
}

// QuizVersion: immutable snapshot of a quiz's content at session-start
// time. Without this, a host who edits a quiz after running it produces
// session reports that reference questions the participants never saw.
model QuizVersion {
  id            String       @id @default(cuid())
  quizId        String?      // nullable: ad-hoc quizzes have no source row
  title         String
  subject       String?
  language      String?
  theme         String?
  snapshot      Json         // the questions array at session-start time
  questionCount Int          @default(0)
  createdAt     DateTime     @default(now())

  quiz     Quiz?         @relation(fields: [quizId], references: [id], onDelete: SetNull)
  sessions GameSession[]

  @@index([quizId, createdAt])
}

model Presentation {
  id        String   @id @default(cuid())
  title     String
  theme     String? // theme id from QUIZ_THEMES catalog; null = default
  slides    Json // array of Slide objects
  userId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User?         @relation(fields: [userId], references: [id])
  sessions GameSession[]

  @@index([userId])
}

model GameSession {
  id               String    @id @default(cuid())
  code             String    @unique // 6-digit room code
  type             String // 'quiz' | 'presentation'
  quizId           String?
  quizVersionId    String?   // Session-5 snapshot — preferred over Quiz.questions for historical session reports
  presentationId   String?
  userId           String?
  hostName         String?
  status           String    @default("waiting") // 'waiting' | 'active' | 'ended'
  results          Json? // aggregate per-slide/question results
  participantCount Int       @default(0)
  createdAt        DateTime  @default(now())
  endedAt          DateTime?

  quiz         Quiz?         @relation(fields: [quizId], references: [id])
  quizVersion  QuizVersion?  @relation(fields: [quizVersionId], references: [id])
  presentation Presentation? @relation(fields: [presentationId], references: [id])
  user         User?         @relation(fields: [userId], references: [id])
  attendees    Attendee[]
  answers      Answer[]

  @@index([userId])
  @@index([quizVersionId])
}

model Attendee {
  id          String      @id @default(cuid())
  sessionId   String
  session     GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  nickname    String
  realName    String?
  email       String?
  archetype   String?
  socketId    String?
  joinedAt    DateTime    @default(now())
  leftAt      DateTime?
  durationSec Int?
  finalScore  Int         @default(0)
  team        String?

  @@index([sessionId])
  @@index([email])
}

// Per-question answer audit log. Persisted at submit time (best-effort,
// fire-and-forget) so scores can be reconstructed if RAM state is lost
// (server restart, redeploy mid-game). The unique constraint also serves as
// anti-replay protection — client outbox retries are safe.
model Answer {
  id            String   @id @default(cuid())
  sessionId     String
  attendeeId    String?
  participantId String // client-generated UUID, stable across reconnects
  questionIndex Int
  answer        Json // raw answer (string | number | array)
  isCorrect     Boolean?
  basePoints    Int      @default(0)
  streakBonus   Int      @default(0)
  points        Int      @default(0)
  timeMs        Int      @default(0)
  confidence    String? // 'sure' | 'unsure' | null
  submittedAt   DateTime @default(now())

  session GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, participantId, questionIndex])
  @@index([sessionId])
  @@index([attendeeId])
}

// ─── CreditGrant (admin-issued AI credit adjustments) ────────────
// Manual grants from the admin compensation flow. Aggregated alongside
// Referral.rewardValue when the quota library computes how many bonus AI
// credits a user has. Negative amounts are allowed — admins can revoke
// grants if needed. Audit trail lives in AdminAuditLog, not here.
model CreditGrant {
  id        String    @id @default(cuid())
  userId    String
  bucket    String // 'questions' | 'enhancements'
  amount    Int // positive = grant, negative = revoke
  reason    String // free-text, required — surfaces in admin UI + email
  expiresAt DateTime? // null = never expires
  grantedBy String // admin user id; intentionally not a FK so audit survives admin deletion
  metadata  Json? // optional ticket id, screenshot link, etc.
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, bucket, expiresAt])
}

// ─── AdminAuditLog (every admin mutation, forever) ──────────────
// Read-only after insert. Source of truth for "who did what, when, why".
// Used by every admin write endpoint — credits/grant in this session,
// grant-pro / refund / data-deletion in future sessions.
model AdminAuditLog {
  id          String   @id @default(cuid())
  actorId     String // admin user id
  actorEmail  String // denormalised so the log survives admin user deletion
  action      String // 'credit_grant' | 'plan_grant' | 'plan_revoke' | etc.
  targetType  String? // 'user' | 'subscription' | 'quiz' | etc.
  targetId    String?
  payload     Json // full request body (sanitised — no auth tokens)
  beforeState Json? // state of target before the action (where applicable)
  afterState  Json? // state of target after the action
  reason      String // required — propagated from the action's reason field
  ipAddress   String? // request IP for forensic context
  userAgent   String? // request UA
  createdAt   DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([targetType, targetId, createdAt])
  @@index([action, createdAt])
}

// ─── WebhookEvent (every inbound webhook, raw) ──────────────────
// Captured before any business logic so we can replay, forensically
// reconstruct, and answer "did we ever receive event X?" without parsing
// Payment.metadata blobs by hand. Idempotency continues to live on
// Payment.providerEventId; this is the audit trail.
model WebhookEvent {
  id           String    @id @default(cuid())
  provider     String   // 'razorpay' | 'stripe' | future
  eventType    String   // e.g. 'payment.captured', 'invoice.paid'
  eventId      String?  // provider-supplied event id
  rawPayload   Json     // full request body
  headers      Json?    // selected headers (signatures, etc.)
  status       String   @default("received") // 'received' | 'processed' | 'failed' | 'duplicate'
  errorMessage String?
  processedAt  DateTime?
  ipAddress    String?
  createdAt    DateTime  @default(now())

  @@index([provider, eventType, createdAt])
  @@index([eventId])
  @@index([status, createdAt])
}

// ─── EmailLog (every email send via the email helper) ────────────
// Powers "did the user actually get the email?" support questions and
// bounce/spam analysis. Provider id (Resend's message id) stored for
// cross-reference. userId is nullable because not every send is to a
// User row (e.g. magic link to a new email address).
model EmailLog {
  id           String   @id @default(cuid())
  userId       String?
  toEmail      String
  subject      String
  category     String   // 'credit_grant' | 'welcome' | 'magic_link' | 'transactional' etc.
  providerId   String?  // Resend message id when send succeeded
  status       String   @default("queued") // 'queued' | 'sent' | 'failed'
  errorMessage String?
  metadata     Json?
  createdAt    DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([category, createdAt])
  @@index([status, createdAt])
}

// ─── Coupon (promotional codes) ─────────────────────────────────
// Admin-created codes. Four kinds: 'credits' grants AI credits via the
// existing CreditGrant flow, 'pro_days' extends Pro plan, 'percent_off' /
// 'amount_off' apply at checkout (Stripe / Razorpay). Per-user and total
// redemption caps prevent abuse; the active+date window controls
// availability.
model Coupon {
  id              String    @id @default(cuid())
  code            String    @unique
  kind            String   // 'credits' | 'pro_days' | 'percent_off' | 'amount_off'
  value           Int      // credits=count, pro_days=days, percent_off=0-100, amount_off=minor unit
  bucket          String?  // only for kind='credits'
  currency        String?  // only for kind='amount_off'
  description     String?
  maxRedemptions  Int?     // null = unlimited
  redemptionCount Int       @default(0)
  perUserLimit    Int       @default(1)
  validFrom       DateTime?
  validUntil      DateTime?
  active          Boolean   @default(true)
  createdBy       String   // admin user id
  metadata        Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  redemptions CouponRedemption[]

  @@index([active, validUntil])
  @@index([kind])
}

model CouponRedemption {
  id           String   @id @default(cuid())
  couponId     String
  userId       String
  appliedTo    String?  // 'subscription' | 'credits'
  appliedRefId String?  // CreditGrant id, Subscription id, etc.
  metadata     Json?
  redeemedAt   DateTime @default(now())

  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, couponId])
  @@index([couponId])
}

// ─── DataDeletionRequest (GDPR / DPDP Act right-to-erasure) ─────
// User files a request to have their data removed. 7-day grace lets
// them cancel; after that an admin (or scheduled job) processes the
// deletion. The row is retained as an audit artefact even after
// completion.
model DataDeletionRequest {
  id             String    @id @default(cuid())
  userId         String
  status         String    @default("pending") // 'pending' | 'approved' | 'completed' | 'cancelled' | 'rejected'
  reason         String?
  requestedAt    DateTime  @default(now())
  graceExpiresAt DateTime
  completedAt    DateTime?
  completedBy    String?   // admin user id when manually completed
  metadata       Json?
  createdAt      DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status, graceExpiresAt])
}

// ─── ModerationFlag (user-submitted reports of inappropriate content) ─
// Same row shape used for spam, hate speech, sexual content,
// copyright complaints. targetType narrows the polymorphic foreign
// key (quiz / session / answer / user).
model ModerationFlag {
  id          String    @id @default(cuid())
  reporterId  String?  // nullable for anonymous attendees
  targetType  String   // 'quiz' | 'session' | 'answer' | 'user'
  targetId    String
  category    String   // 'spam' | 'hate' | 'sexual' | 'copyright' | 'other'
  details     String?
  status      String    @default("open") // 'open' | 'reviewing' | 'resolved' | 'dismissed'
  disposition String?  // 'removed' | 'no_action' | 'banned'
  reviewedBy  String?
  reviewedAt  DateTime?
  metadata    Json?
  createdAt   DateTime  @default(now())

  reporter User? @relation("moderation_reports", fields: [reporterId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([targetType, targetId])
}

// ─── FeatureFlag (server-side feature toggle) ───────────────────
// Three release modes: boolean kill-switch (enabled=true/false), %
// rollout (deterministic hash of userId + key), or per-user allowlist
// via FeatureFlagAssignment.
model FeatureFlag {
  id             String   @id @default(cuid())
  key            String   @unique // e.g. 'pdf_vision_tier'
  description    String?
  enabled        Boolean  @default(false) // master switch
  rolloutPercent Int      @default(0)     // 0-100
  metadata       Json?
  createdBy      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  assignments FeatureFlagAssignment[]

  @@index([enabled])
}

model FeatureFlagAssignment {
  id        String   @id @default(cuid())
  flagId    String
  userId    String
  enabled   Boolean  // explicit override (force on or off)
  reason    String?
  createdBy String?
  createdAt DateTime @default(now())

  flag FeatureFlag @relation(fields: [flagId], references: [id], onDelete: Cascade)
  user User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([flagId, userId])
  @@index([userId])
}

// ─── Referral (reward tracking) ─────────────────────────────────
model Referral {
  id          String    @id @default(cuid())
  referrerId  String // user who shared the code
  refereeId   String // user who signed up
  status      String    @default("pending") // "pending" | "completed" | "rewarded"
  rewardType  String? // "ai_credits"
  rewardValue Int? // e.g., 10 (bonus AI credits)
  rewardedAt  DateTime?
  createdAt   DateTime  @default(now())

  referrer User @relation("referrals_given", fields: [referrerId], references: [id], onDelete: Cascade)
  referee  User @relation("referrals_received", fields: [refereeId], references: [id], onDelete: Cascade)

  @@unique([referrerId, refereeId])
  @@index([referrerId])
}
